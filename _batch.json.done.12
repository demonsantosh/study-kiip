{
  "[보기] 회의할 때 실수한 것이 있어요?": { "bn":"মিটিংয়ের সময় কি কোনো ভুল করেছিলেন?","ru":"Вы допустили какие-нибудь ошибки во время совещания?","he":"עשית טעויות במהלך הפגישה?","ms":"Adakah anda buat sebarang kesilapan semasa mesyuarat?","vi":"Bạn có mắc lỗi nào trong lúc họp không?","id":"Apakah Anda membuat kesalahan saat rapat?","si":"රැස්වීමේදී ඔබ කිසියම් වැරදීමක් කළාද?","pt":"Você cometeu algum erro durante a reunião?","fr":"Avez-vous fait des erreurs pendant la réunion ?","ta":"கூட்டத்தின் போது ஏதேனும் தவறு செய்தீர்களா?" },
  "[보기] 어제 청소를 하다가 부딪혀서 꽃병을 깨고 말았어요.": { "bn":"গতকাল পরিষ্কার করার সময় ধাক্কা লেগে ফুলদানিটা ভেঙে ফেললাম।","ru":"Вчера во время уборки я на что-то наткнулся и в итоге разбил вазу.","he":"אתמול תוך כדי ניקיון נתקלתי במשהו ובסוף שברתי את האגרטל.","ms":"Semalam semasa mengemas, saya terlanggar sesuatu dan akhirnya memecahkan pasu bunga.","vi":"Hôm qua khi đang dọn dẹp, tôi va phải cái gì đó và cuối cùng làm vỡ bình hoa.","id":"Kemarin saat membersihkan, saya menabrak sesuatu dan akhirnya memecahkan vas bunga.","si":"ඊයේ පිරිසිදු කරන අතරතුර යමකට හැපී අන්තිමට මල් බඳුන කැඩුවා.","pt":"Ontem, enquanto limpava, esbarrei em algo e acabei quebrando o vaso.","fr":"Hier, en faisant le ménage, j'ai heurté quelque chose et j'ai fini par casser le vase.","ta":"நேற்று சுத்தம் செய்யும் போது எதிலோ மோதி, கடைசியில் மலர் ஜாடியை உடைத்துவிட்டேன்." },
  "청소할 때: 청소기를 돌리다가 발을 헛디뎌서 넘어지고 말았어요.": { "bn":"ভ্যাকুয়াম করার সময় পা পিছলে গিয়ে পড়ে গেলাম।","ru":"Пылесося, я оступился и в итоге упал.","he":"תוך כדי שאיבת אבק איבדתי שיווי משקל ובסוף נפלתי.","ms":"Semasa menggunakan pembersih vakum, saya tersilap langkah dan akhirnya jatuh.","vi":"Khi đang hút bụi, tôi bị trượt chân và cuối cùng bị ngã.","id":"Saat menyedot debu, saya salah langkah dan akhirnya jatuh.","si":"වැකුම් කරන අතරතුර පය ලිස්සා අන්තිමට වැටුණා.","pt":"Enquanto passava o aspirador, perdi o equilíbrio e acabei caindo.","fr":"En passant l'aspirateur, j'ai perdu l'équilibre et j'ai fini par tomber.","ta":"வாக்யூம் செய்யும் போது கால் தடுமாறி கடைசியில் விழுந்துவிட்டேன்." },
  "다이어트를 할 때: 참으려고 했지만 결국 야식을 먹고 말았어요.": { "bn":"সংযত থাকার চেষ্টা করেছিলাম, কিন্তু শেষমেশ রাতের খাবার খেয়ে ফেললাম।","ru":"Я пытался сдержаться, но в итоге всё же поел на ночь.","he":"ניסיתי להתאפק, אבל בסוף אכלתי חטיף לילה.","ms":"Saya cuba menahan diri, tetapi akhirnya makan juga snek tengah malam.","vi":"Tôi đã cố nhịn, nhưng cuối cùng vẫn ăn khuya mất.","id":"Saya sudah mencoba menahan diri, tapi akhirnya makan camilan tengah malam juga.","si":"මම වළක්වා ගන්න උත්සාහ කළත් අන්තිමට රෑ කෑම කාලා දැම්මා.","pt":"Tentei me segurar, mas no fim acabei comendo um lanche tarde da noite.","fr":"J'ai essayé de me retenir, mais j'ai fini par manger un en-cas nocturne.","ta":"அடக்கிக் கொள்ள முயற்சித்தேன், ஆனால் கடைசியில் இரவு உணவை சாப்பிட்டுவிட்டேன்." },
  "중요한 시험이 있을 때: 너무 긴장해서 아는 문제도 틀리고 말았어요.": { "bn":"এত নার্ভাস ছিলাম যে জানা প্রশ্নটাও ভুল করে ফেললাম।","ru":"Я так нервничал, что в итоге ошибся даже в вопросе, который знал.","he":"הייתי כל כך לחוץ שבסוף טעיתי אפילו בשאלה שידעתי.","ms":"Saya terlalu gugup sehingga akhirnya salah menjawab soalan yang saya tahu pun.","vi":"Tôi lo lắng đến mức cuối cùng làm sai cả câu hỏi mà mình biết.","id":"Saya begitu gugup sampai akhirnya salah menjawab soal yang saya tahu sekalipun.","si":"මම ඉතා කලබල වූ නිසා දැනගෙන හිටිය ප්‍රශ්නෙත් අන්තිමට වැරදුණා.","pt":"Fiquei tão nervoso que acabei errando até uma questão que eu sabia.","fr":"J'étais si nerveux que j'ai fini par me tromper même sur une question que je connaissais.","ta":"நான் மிகவும் பதற்றமடைந்ததால், தெரிந்த கேள்வியையும் கடைசியில் தவறாக எழுதிவிட்டேன்." },
  "예문 ① 청소하다가 실수로 컵을 떨어뜨리고 말았어요.": { "bn":"পরিষ্কার করার সময় ভুলবশত কাপটা ফেলে দিলাম।","ru":"Во время уборки я случайно уронил чашку.","he":"תוך כדי ניקיון הפלתי בטעות את הכוס.","ms":"Semasa mengemas, saya tanpa sengaja menjatuhkan cawan.","vi":"Khi đang dọn dẹp, tôi lỡ tay làm rơi cái cốc.","id":"Saat membersihkan, saya tidak sengaja menjatuhkan cangkir.","si":"පිරිසිදු කරන අතරතුර වැරදීමකින් කෝප්පය බිම දැම්මා.","pt":"Enquanto limpava, deixei o copo cair sem querer.","fr":"En faisant le ménage, j'ai fait tomber la tasse par accident.","ta":"சுத்தம் செய்யும் போது தற்செயலாக கோப்பையை கீழே விழவிட்டேன்." },
  "예문 ② 걸레질을 하다가 미끄러져서 넘어지고 말았어요.": { "bn":"মপ করার সময় পিছলে গিয়ে পড়ে গেলাম।","ru":"Во время мытья пола я поскользнулся и в итоге упал.","he":"תוך כדי שטיפת הרצפה החלקתי ובסוף נפלתי.","ms":"Semasa mengemop lantai, saya tergelincir dan akhirnya jatuh.","vi":"Khi đang lau nhà, tôi bị trượt và cuối cùng bị ngã.","id":"Saat mengepel, saya terpeleset dan akhirnya jatuh.","si":"බිම පිසදමන අතරතුර ලිස්සා අන්තිමට වැටුණා.","pt":"Enquanto passava o pano no chão, escorreguei e acabei caindo.","fr":"En passant la serpillière, j'ai glissé et j'ai fini par tomber.","ta":"துடைக்கும் போது வழுக்கி கடைசியில் விழுந்துவிட்டேன்." },
  "예문 ③ 책장을 정리하다가 오래된 사진을 버리고 말았어요.": { "bn":"বইয়ের তাক গোছানোর সময় একটা পুরনো ছবি ফেলে দিলাম।","ru":"Разбирая книжную полку, я в итоге выбросил старую фотографию.","he":"תוך כדי סידור המדף בסוף זרקתי תמונה ישנה.","ms":"Semasa mengemas rak buku, saya akhirnya terbuang sekeping gambar lama.","vi":"Khi sắp xếp kệ sách, tôi lỡ vứt mất một tấm ảnh cũ.","id":"Saat merapikan rak buku, saya akhirnya membuang sebuah foto lama.","si":"පොත් රාක්කය පිළිවෙළ කරන අතරතුර පරණ ඡායාරූපයක් අන්තිමට ඉවත දැම්මා.","pt":"Enquanto organizava a estante, acabei jogando fora uma foto antiga.","fr":"En rangeant l'étagère, j'ai fini par jeter une vieille photo.","ta":"புத்தக அலமாரியை ஒழுங்குபடுத்தும் போது, ஒரு பழைய புகைப்படத்தை கடைசியில் தூக்கி எறிந்துவிட்டேன்." },
  "예문 ① 다이어트 중인데 친구가 권해서 케이크를 먹고 말았어요.": { "bn":"আমি ডায়েট করছি, কিন্তু বন্ধু সাধায় বলে কেক খেয়ে ফেললাম।","ru":"Я на диете, но друг предложил, и в итоге я съел торт.","he":"אני בדיאטה, אבל חבר הציע ובסוף אכלתי עוגה.","ms":"Saya sedang berdiet, tetapi kawan menawarkan, jadi akhirnya makan kek juga.","vi":"Tôi đang ăn kiêng, nhưng bạn mời nên cuối cùng vẫn ăn bánh mất.","id":"Saya sedang berdiet, tapi teman menawari, jadi akhirnya makan kue juga.","si":"මම ඩයට් කරනවා, නමුත් යාළුවා දුන්න නිසා අන්තිමට කේක් කාලා දැම්මා.","pt":"Estou de dieta, mas meu amigo ofereceu, então acabei comendo bolo.","fr":"Je suis au régime, mais un ami m'en a proposé, alors j'ai fini par manger du gâteau.","ta":"நான் உணவுக்கட்டுப்பாட்டில் இருக்கிறேன், ஆனால் நண்பர் கொடுத்ததால் கடைசியில் கேக் சாப்பிட்டுவிட்டேன்." },
  "예문 ② 운동을 쉬려고 하다가 결국 일주일이나 쉬고 말았어요.": { "bn":"ব্যায়াম থেকে একটু বিশ্রাম নেব ভেবেছিলাম, কিন্তু শেষে পুরো এক সপ্তাহ বিশ্রাম নিয়ে ফেললাম।","ru":"Я хотел лишь передохнуть от тренировок, но в итоге отдыхал целую неделю.","he":"התכוונתי רק לנוח מהאימונים, אבל בסוף נחתי שבוע שלם.","ms":"Saya berniat berehat seketika daripada bersenam, tetapi akhirnya berehat sampai seminggu.","vi":"Tôi định nghỉ tập một chút, nhưng cuối cùng lại nghỉ hẳn cả tuần.","id":"Saya berniat istirahat sebentar dari olahraga, tapi akhirnya istirahat sampai seminggu penuh.","si":"මම ව්‍යායාමයෙන් ටිකක් විවේක ගන්න හිතුවත් අන්තිමට සතියක්ම විවේක ගත්තා.","pt":"Eu pretendia só descansar do exercício, mas no fim acabei descansando uma semana inteira.","fr":"Je voulais juste faire une pause dans le sport, mais j'ai fini par me reposer une semaine entière.","ta":"உடற்பயிற்சியிலிருந்து சிறிது ஓய்வெடுக்க நினைத்தேன், ஆனால் கடைசியில் முழு வாரமும் ஓய்வெடுத்துவிட்டேன்." },
  "예문 ③ 밤에 배가 고파서 라면을 끓여 먹고 말았어요.": { "bn":"রাতে খিদে পেয়ে যাওয়ায় রামেন রান্না করে খেয়ে ফেললাম।","ru":"Ночью я проголодался и в итоге сварил и съел рамен.","he":"התחשק לי לאכול בלילה, אז בסוף בישלתי ואכלתי ראמן.","ms":"Saya lapar pada waktu malam, jadi akhirnya masak dan makan ramen.","vi":"Ban đêm tôi thấy đói nên cuối cùng đã nấu và ăn mì ramen.","id":"Saya lapar di malam hari, jadi akhirnya memasak dan makan ramen.","si":"රෑට බඩගිනි වුණ නිසා අන්තිමට රාමන් උයලා කෑවා.","pt":"Fiquei com fome à noite, então acabei cozinhando e comendo lámen.","fr":"J'ai eu faim la nuit, alors j'ai fini par préparer et manger des ramen.","ta":"இரவில் பசித்ததால், கடைசியில் ராமன் சமைத்து சாப்பிட்டுவிட்டேன்." },
  "예문 ① 긴장해서 이름 쓰는 것을 깜빡하고 말았어요.": { "bn":"এত নার্ভাস ছিলাম যে নাম লিখতেই ভুলে গেলাম।","ru":"Я так нервничал, что в итоге забыл написать своё имя.","he":"הייתי כל כך לחוץ שבסוף שכחתי לכתוב את שמי.","ms":"Saya terlalu gugup sehingga akhirnya terlupa menulis nama.","vi":"Tôi lo lắng đến mức cuối cùng quên viết cả tên mình.","id":"Saya begitu gugup sampai akhirnya lupa menulis nama.","si":"මම ඉතා කලබල වූ නිසා නම ලියන්නවත් අන්තිමට අමතක වුණා.","pt":"Fiquei tão nervoso que acabei esquecendo de escrever meu nome.","fr":"J'étais si nerveux que j'ai fini par oublier d'écrire mon nom.","ta":"நான் மிகவும் பதற்றமடைந்ததால், கடைசியில் என் பெயரை எழுதவே மறந்துவிட்டேன்." },
  "예문 ② 늦잠을 자서 시험에 지각하고 말았어요.": { "bn":"বেশি ঘুমিয়ে পড়ায় পরীক্ষায় দেরি করে ফেললাম।","ru":"Я проспал и в итоге опоздал на экзамен.","he":"התעוררתי מאוחר ובסוף איחרתי לבחינה.","ms":"Saya terlebih tidur, jadi akhirnya lewat ke peperiksaan.","vi":"Tôi ngủ quên nên cuối cùng đã đến muộn buổi thi.","id":"Saya kesiangan, jadi akhirnya terlambat ke ujian.","si":"මම වැඩිපුර නිදාගත් නිසා විභාගයට අන්තිමට පරක්කු වුණා.","pt":"Dormi demais, então acabei me atrasando para a prova.","fr":"J'ai fait la grasse matinée, alors j'ai fini par être en retard à l'examen.","ta":"நான் அதிகமாக தூங்கிவிட்டதால், கடைசியில் தேர்வுக்கு தாமதமாகிவிட்டேன்." },
  "예문 ③ 시간이 부족해서 마지막 문제를 못 풀고 말았어요.": { "bn":"সময় কম পড়ায় শেষ প্রশ্নটা আর সমাধান করতে পারলাম না।","ru":"Мне не хватило времени, и в итоге я не решил последнюю задачу.","he":"לא הספיק לי הזמן, אז בסוף לא פתרתי את השאלה האחרונה.","ms":"Masa saya tidak cukup, jadi akhirnya soalan terakhir tidak dapat saya selesaikan.","vi":"Tôi hết thời gian nên cuối cùng không giải được câu cuối.","id":"Waktu saya tidak cukup, jadi akhirnya soal terakhir tidak sempat saya kerjakan.","si":"වේලාව මදි වූ නිසා අන්තිම ප්‍රශ්නය අන්තිමට කරන්න බැරි වුණා.","pt":"Fiquei sem tempo, então acabei não resolvendo a última questão.","fr":"Je manquais de temps, alors je n'ai finalement pas pu résoudre la dernière question.","ta":"எனக்கு நேரம் போதவில்லை, அதனால் கடைசி கேள்வியை கடைசியில் தீர்க்க முடியவில்லை." },
  "고천: 요즘은 유행어가 빨리 바뀌어서 무슨 말인지 이해를 잘 못하겠어요.": { "bn":"গোচেওন: আজকাল চলতি শব্দগুলো এত দ্রুত বদলায় যে মানে কী তা ঠিকমতো বুঝতে পারি না।","ru":"Гочхон: В наши дни модные словечки меняются так быстро, что я не могу толком понять, что они значат.","he":"גוצ'ון: בימינו מילות האופנה מתחלפות כל כך מהר שאני לא ממש מבין מה הן אומרות.","ms":"Gocheon: Zaman sekarang perkataan trend berubah begitu cepat sampai saya tak berapa faham maksudnya.","vi":"Gocheon: Dạo này từ ngữ thịnh hành thay đổi nhanh đến mức tôi không hiểu rõ chúng nghĩa là gì.","id":"Gocheon: Zaman sekarang kata-kata tren berubah begitu cepat sampai saya kurang paham artinya.","si":"ගොචොන්: මේ දවස්වල විලාසිතා වචන ඉතා ඉක්මනට වෙනස් වන නිසා ඒවායේ තේරුම හරියට තේරෙන්නේ නෑ.","pt":"Gocheon: Hoje em dia as gírias mudam tão rápido que não consigo entender bem o que significam.","fr":"Gocheon : De nos jours, les mots à la mode changent si vite que je n'arrive pas vraiment à comprendre ce qu'ils veulent dire.","ta":"கோச்சன்: இந்நாட்களில் நடப்பு வார்த்தைகள் மிக வேகமாக மாறுவதால், அவற்றின் அர்த்தம் எனக்கு சரியாக புரிவதில்லை." },
  "라민: 저도 모르는 유행어가 많은데 그냥 따라 하면서 아는 척해요.": { "bn":"রামিন: আমারও অনেক চলতি শব্দ জানা নেই, কিন্তু আমি শুধু সঙ্গে তাল মিলিয়ে জানার ভান করি।","ru":"Рамин: Я тоже не знаю многих модных словечек, но просто подхватываю и делаю вид, что знаю.","he":"ראמין: גם אני לא מכיר הרבה מילות סלנג, אבל אני פשוט זורם ומעמיד פנים שאני מכיר.","ms":"Ramin: Saya pun banyak tak tahu perkataan trend, tapi saya cuma ikut sahaja dan berpura-pura tahu.","vi":"Ramin: Tôi cũng có nhiều từ lóng không biết, nhưng tôi chỉ hùa theo và giả vờ biết.","id":"Ramin: Saya juga banyak tidak tahu kata gaul, tapi saya hanya ikut-ikutan dan pura-pura tahu.","si":"රාමින්: මටත් නොදන්නා විලාසිතා වචන ගොඩක් තියෙනවා, නමුත් මම ඒවා අනුගමනය කරලා දන්නවා වගේ මවා පානවා විතරයි.","pt":"Ramin: Também há muitas gírias que eu não conheço, mas eu apenas acompanho e finjo que conheço.","fr":"Ramin : Moi aussi, il y a beaucoup d'expressions à la mode que je ne connais pas, mais je me contente de suivre et de faire semblant de les connaître.","ta":"ரமின்: எனக்கும் தெரியாத நடப்பு வார்த்தைகள் நிறைய உண்டு, ஆனால் நான் உடன்போய் தெரிந்தது போல் நடிக்கிறேன்." },
  "친구가 준 선물이 마음에 안 들 때 마음에 안 들어도 기분이 좋은 척해요.": { "bn":"বন্ধুর দেওয়া উপহার পছন্দ না হলে, পছন্দ না হলেও খুশি হওয়ার ভান করি।","ru":"Когда мне не нравится подарок друга, даже если он не нравится, я делаю вид, что рад.","he":"כשמתנה שחבר נתן לא מוצאת חן בעיניי, גם אם היא לא מוצאת חן, אני מעמיד פנים שאני שמח.","ms":"Apabila hadiah daripada kawan tidak saya sukai, walaupun tidak suka, saya berpura-pura gembira.","vi":"Khi không thích món quà bạn tặng, dù không thích tôi vẫn giả vờ vui.","id":"Ketika saya tidak suka hadiah dari teman, meskipun tidak suka, saya pura-pura senang.","si":"යාළුවා දුන්න තෑග්ග මට රුචි නැති වුණත්, රුචි නැති වුණත් සතුටු වෙනවා වගේ මවා පානවා.","pt":"Quando não gosto de um presente que um amigo deu, mesmo sem gostar, finjo estar feliz.","fr":"Quand je n'aime pas un cadeau qu'un ami m'a offert, même si je ne l'aime pas, je fais semblant d'être content.","ta":"நண்பர் கொடுத்த பரிசு எனக்குப் பிடிக்காதபோது, பிடிக்காவிட்டாலும் மகிழ்ச்சியாக இருப்பது போல் நடிக்கிறேன்." },
  "[보기] 받기 싫은 전화를 받았을 때 바쁜 척해요.": { "bn":"যে ফোন ধরতে চাই না তা এলে, ব্যস্ত থাকার ভান করি।","ru":"Когда мне звонят и я не хочу отвечать, я делаю вид, что занят.","he":"כשמתקשרים אליי ואני לא רוצה לענות, אני מעמיד פנים שאני עסוק.","ms":"Apabila menerima panggilan yang saya tak mahu jawab, saya berpura-pura sibuk.","vi":"Khi nhận cuộc gọi mà tôi không muốn nghe, tôi giả vờ bận.","id":"Ketika menerima telepon yang tidak ingin saya angkat, saya pura-pura sibuk.","si":"මට උත්තර දෙන්න අකමැති කෝල් එකක් ආවම, මම කාර්යබහුල වගේ මවා පානවා.","pt":"Quando recebo uma ligação que não quero atender, finjo estar ocupado.","fr":"Quand je reçois un appel auquel je ne veux pas répondre, je fais semblant d'être occupé.","ta":"பதிலளிக்க விரும்பாத அழைப்பு வரும்போது, வேலையாக இருப்பது போல் நடிக்கிறேன்." },
  "라민: 이링 씨는 한국에 온 지 오래돼서 이제 적응이 다 됐죠.": { "bn":"রামিন: আপনি অনেক দিন কোরিয়ায় আছেন, তাই এখন নিশ্চয়ই পুরোপুরি মানিয়ে গেছেন।","ru":"Рамин: Вы уже давно в Корее, так что, наверное, полностью освоились.","he":"ראמין: את בקוריאה כבר הרבה זמן, אז בטח כבר הסתגלת לגמרי.","ms":"Ramin: Awak sudah lama di Korea, jadi tentu sudah menyesuaikan diri sepenuhnya sekarang.","vi":"Ramin: Bạn ở Hàn Quốc đã lâu rồi nên chắc giờ đã thích nghi hoàn toàn.","id":"Ramin: Kamu sudah lama di Korea, jadi pasti sekarang sudah benar-benar beradaptasi.","si":"රාමින්: ඔබ කොරියාවේ ගොඩක් කල් ඉන්න නිසා දැන් සම්පූර්ණයෙන්ම හුරු වෙලා ඇති නේද?","pt":"Ramin: Você está na Coreia há muito tempo, então já deve estar totalmente adaptado agora.","fr":"Ramin : Vous êtes en Corée depuis longtemps, alors vous devez être tout à fait adapté maintenant.","ta":"ரமின்: நீங்கள் கொரியாவில் நீண்ட காலமாக இருப்பதால், இப்போது முழுமையாக பழகியிருப்பீர்கள்." },
  "이링: 생활하는 건 괜찮은데 오래 살수록 한국어가 점점 더 어려워지는 것 같아요.": { "bn":"ইলিং: এখানে থাকতে সমস্যা নেই, কিন্তু যত বেশি দিন থাকি, কোরিয়ান যেন তত কঠিন হয়ে ওঠে।","ru":"Иринг: Жить здесь нормально, но чем дольше я живу, тем труднее кажется корейский.","he":"אירינג: לחיות כאן זה בסדר, אבל ככל שאני גר כאן יותר זמן, נראה שהקוריאנית נעשית קשה יותר.","ms":"Iring: Hidup di sini tidak mengapa, tetapi semakin lama saya tinggal, bahasa Korea nampak semakin sukar.","vi":"Iring: Sống ở đây thì ổn, nhưng càng sống lâu tôi càng thấy tiếng Hàn khó hơn.","id":"Iring: Tinggal di sini tidak masalah, tapi semakin lama saya tinggal, bahasa Korea terasa semakin sulit.","si":"අයිරිං: මෙහෙ ජීවත් වෙන එකේ අවුලක් නෑ, නමුත් වැඩි කල් ඉන්න තරමට කොරියානු භාෂාව වඩ වඩාත් අමාරු වෙනවා වගේ.","pt":"Iring: Morar aqui é tranquilo, mas quanto mais tempo eu vivo aqui, mais difícil o coreano parece ficar.","fr":"Iring : Vivre ici, ça va, mais plus je vis ici longtemps, plus le coréen semble devenir difficile.","ta":"அயிரிங்: இங்கு வாழ்வது பரவாயில்லை, ஆனால் எவ்வளவு காலம் வாழ்கிறேனோ, அவ்வளவுக்கு கொரிய மொழி கடினமாகத் தெரிகிறது." },
  "이링: 어휘나 문법은 많이 알아도 의도한 대로 말이 잘 안 나올 때가 많아요.": { "bn":"ইলিং: অনেক শব্দ আর ব্যাকরণ জানলেও, প্রায়ই যেভাবে চাই সেভাবে কথা বের হয় না।","ru":"Иринг: Хотя я знаю много слов и грамматики, слова часто выходят не так, как я задумал.","he":"אירינג: למרות שאני יודע הרבה אוצר מילים ודקדוק, לעיתים קרובות המילים לא יוצאות כמו שהתכוונתי.","ms":"Iring: Walaupun saya tahu banyak kosa kata dan tatabahasa, selalu juga perkataan tidak keluar seperti yang saya niatkan.","vi":"Iring: Dù biết nhiều từ vựng và ngữ pháp, nhưng nhiều khi lời nói không thốt ra được như tôi muốn.","id":"Iring: Meskipun saya tahu banyak kosakata dan tata bahasa, sering kali kata-kata tidak keluar seperti yang saya maksudkan.","si":"අයිරිං: වචන සහ ව්‍යාකරණ ගොඩක් දැනගෙන හිටියත්, බොහෝ විට මට අවශ්‍ය විදිහට වචන පිට වෙන්නේ නෑ.","pt":"Iring: Mesmo sabendo muito vocabulário e gramática, muitas vezes as palavras não saem como eu pretendo.","fr":"Iring : Même si je connais beaucoup de vocabulaire et de grammaire, souvent les mots ne sortent pas comme je le voudrais.","ta":"அயிரிங்: நிறைய சொற்களும் இலக்கணமும் தெரிந்திருந்தாலும், நான் நினைத்தபடி பேச்சு பல நேரங்களில் வெளிவருவதில்லை." },
  "보기 ① 발음이 부정확해서 사람들이 자꾸 다시 질문한다.": { "bn":"আমার উচ্চারণ ঠিক নয়, তাই লোকজন বারবার আবার জিজ্ঞেস করে।","ru":"У меня неточное произношение, поэтому люди постоянно переспрашивают.","he":"ההגייה שלי לא מדויקת, ולכן אנשים כל הזמן מבקשים שאחזור.","ms":"Sebutan saya tidak tepat, jadi orang selalu meminta saya mengulang.","vi":"Phát âm của tôi không chuẩn nên mọi người cứ hỏi lại.","id":"Pelafalan saya kurang tepat, jadi orang-orang sering meminta saya mengulang.","si":"මගේ උච්චාරණය නිවැරදි නැති නිසා මිනිස්සු නැවත නැවත අහනවා.","pt":"Minha pronúncia é imprecisa, então as pessoas ficam me pedindo para repetir.","fr":"Ma prononciation n'est pas exacte, alors les gens me demandent sans cesse de répéter.","ta":"என் உச்சரிப்பு சரியாக இல்லாததால், மக்கள் மீண்டும் மீண்டும் கேட்கிறார்கள்." },
  "보기 ② 한국어를 배울 때 표준어만 배워서 사투리 쓰기가 쉽지 않다.": { "bn":"কোরিয়ান শেখার সময় শুধু প্রমিত ভাষা শিখেছি, তাই আঞ্চলিক ভাষা ব্যবহার করা সহজ নয়।","ru":"Изучая корейский, я учил только литературный язык, поэтому пользоваться диалектом непросто.","he":"כשלמדתי קוריאנית למדתי רק את השפה התקנית, ולכן לא קל להשתמש בניב.","ms":"Semasa belajar bahasa Korea, saya hanya belajar bahasa baku, jadi menggunakan loghat tidaklah mudah.","vi":"Khi học tiếng Hàn tôi chỉ học ngôn ngữ chuẩn, nên dùng tiếng địa phương không dễ.","id":"Saat belajar bahasa Korea saya hanya belajar bahasa baku, jadi menggunakan dialek tidak mudah.","si":"කොරියානු ඉගෙන ගන්නකොට මම ප්‍රමිත භාෂාව විතරයි ඉගෙන ගත්තේ, ඒ නිසා පළාත් බස පාවිච්චි කරන එක ලේසි නෑ.","pt":"Quando aprendi coreano, só aprendi a língua padrão, então usar o dialeto não é fácil.","fr":"Quand j'ai appris le coréen, je n'ai appris que la langue standard, alors utiliser le dialecte n'est pas facile.","ta":"கொரிய மொழி கற்கும்போது நான் நியம மொழியை மட்டுமே கற்றேன், அதனால் வட்டார வழக்கைப் பயன்படுத்துவது எளிதல்ல." },
  "보기 ③ 신조어나 유행어를 따라 하고 싶은데 너무 빨리 바뀐다.": { "bn":"নতুন আর চলতি শব্দগুলো অনুসরণ করতে চাই, কিন্তু সেগুলো খুব দ্রুত বদলে যায়।","ru":"Я хочу успевать за новыми и модными словами, но они меняются слишком быстро.","he":"אני רוצה להתעדכן במילים חדשות ואופנתיות, אבל הן מתחלפות מהר מדי.","ms":"Saya mahu mengikut perkataan baharu dan trend, tetapi ia berubah terlalu cepat.","vi":"Tôi muốn theo kịp những từ mới và thịnh hành, nhưng chúng thay đổi quá nhanh.","id":"Saya ingin mengikuti kata-kata baru dan tren, tetapi kata-kata itu berubah terlalu cepat.","si":"අලුත් සහ විලාසිතා වචන අනුගමනය කරන්න ඕන, නමුත් ඒවා ඉතා ඉක්මනට වෙනස් වෙනවා.","pt":"Quero acompanhar as palavras novas e da moda, mas elas mudam rápido demais.","fr":"Je veux suivre les mots nouveaux et à la mode, mais ils changent trop vite.","ta":"புதிய, நடப்பு வார்த்தைகளைப் பின்பற்ற விரும்புகிறேன், ஆனால் அவை மிக வேகமாக மாறிவிடுகின்றன." },
  "예시 ① 높임말이 헷갈려서 윗사람에게 실수할 때가 많아요.": { "bn":"সম্মানসূচক ভাষা গুলিয়ে ফেলি, তাই গুরুজনদের সঙ্গে প্রায়ই ভুল করি।","ru":"Я путаюсь в вежливых формах, поэтому часто ошибаюсь со старшими.","he":"לשון הכבוד מבלבלת אותי, ולכן אני טועה לעיתים קרובות מול אנשים בכירים ממני.","ms":"Bahasa hormat mengelirukan saya, jadi saya selalu buat silap dengan orang yang lebih tua.","vi":"Kính ngữ làm tôi bối rối nên tôi thường mắc lỗi với người bề trên.","id":"Bahasa hormat membingungkan saya, jadi saya sering salah kepada orang yang lebih senior.","si":"ගෞරව වචන මට අවුල් වන නිසා, වැඩිහිටියන් සමඟ මම නිතර වැරදි කරනවා.","pt":"Os honoríficos me confundem, então costumo cometer erros com pessoas mais velhas.","fr":"Les formes honorifiques m'embrouillent, alors je fais souvent des erreurs avec les personnes plus âgées.","ta":"மரியாதைச் சொற்கள் என்னைக் குழப்புவதால், மூத்தவர்களிடம் நான் அடிக்கடி தவறு செய்கிறேன்." },
  "예시 ② 띄어쓰기가 어려워서 글을 쓸 때 자주 틀려요.": { "bn":"শব্দের ফাঁক দেওয়া কঠিন, তাই লেখার সময় প্রায়ই ভুল করি।","ru":"Пробелы между словами даются трудно, поэтому при письме я часто ошибаюсь.","he":"הרווחים בין המילים קשים לי, ולכן אני טועה לעיתים קרובות בכתיבה.","ms":"Jarak antara perkataan susah, jadi saya selalu buat silap semasa menulis.","vi":"Việc viết cách chữ rất khó nên tôi thường mắc lỗi khi viết.","id":"Pemenggalan spasi sulit, jadi saya sering salah saat menulis.","si":"වචන අතර හිස්තැන් තැබීම අමාරු නිසා, ලියනකොට මම නිතර වැරදි කරනවා.","pt":"O espaçamento é difícil, então costumo errar quando escrevo.","fr":"Les espaces entre les mots sont difficiles, alors je fais souvent des fautes en écrivant.","ta":"சொற்களுக்கிடையேயான இடைவெளி கடினமாக இருப்பதால், எழுதும்போது நான் அடிக்கடி தவறு செய்கிறேன்." },
  "잠시드: 거래처하고 중요한 회의가 있다고 들었는데 잘 끝났어요?": { "bn":"জামশিদ: শুনলাম আপনার ক্লায়েন্টের সঙ্গে একটা গুরুত্বপূর্ণ মিটিং ছিল—ভালোভাবে শেষ হয়েছে তো?","ru":"Джамшид: Я слышал, у вас была важная встреча с клиентом — она прошла хорошо?","he":"ג'משיד: שמעתי שהייתה לך פגישה חשובה עם הלקוח — היא הסתיימה בטוב?","ms":"Jamshid: Saya dengar awak ada mesyuarat penting dengan pelanggan — adakah ia berakhir dengan baik?","vi":"Jamshid: Tôi nghe nói bạn có cuộc họp quan trọng với khách hàng — mọi việc kết thúc tốt chứ?","id":"Jamshid: Saya dengar kamu ada rapat penting dengan klien — apakah berakhir dengan baik?","si":"ජම්ෂිද්: ඔබට ගනුදෙනුකරු සමඟ වැදගත් රැස්වීමක් තිබුණා කියලා ඇහුවා — එය හොඳින් අවසන් වුණාද?","pt":"Jamshid: Ouvi dizer que você teve uma reunião importante com o cliente — terminou bem?","fr":"Jamshid : J'ai entendu dire que vous aviez une réunion importante avec le client — est-ce que ça s'est bien terminé ?","ta":"ஜம்ஷித்: உங்களுக்கு வாடிக்கையாளருடன் ஒரு முக்கியமான கூட்டம் இருந்ததாகக் கேள்விப்பட்டேன் — நன்றாக முடிந்ததா?" },
  "잠시드: 회의 때문에 걱정 많이 했는데 그렇게 끝나서 많이 아쉽겠어요.": { "bn":"জামশিদ: মিটিং নিয়ে অনেক দুশ্চিন্তা করেছিলেন, তাই এভাবে শেষ হওয়ায় নিশ্চয়ই খুব হতাশ লাগছে।","ru":"Джамшид: Вы так переживали из-за встречи, что такой исход, наверное, очень огорчает.","he":"ג'משיד: דאגת מאוד לגבי הפגישה, אז זה בטח מאוד מאכזב שהיא הסתיימה כך.","ms":"Jamshid: Awak sangat risau tentang mesyuarat itu, jadi tentu sangat mengecewakan apabila ia berakhir begitu.","vi":"Jamshid: Bạn đã lo lắng nhiều cho cuộc họp, nên kết thúc như vậy chắc hẳn rất đáng tiếc.","id":"Jamshid: Kamu sangat khawatir tentang rapat itu, jadi pasti sangat mengecewakan berakhir seperti itu.","si":"ජම්ෂිද්: ඔබ රැස්වීම ගැන ගොඩක් කනස්සල්ලට පත් වුණ නිසා, එහෙම අවසන් වීම ගොඩක් කණගාටුදායක ඇති.","pt":"Jamshid: Você se preocupou muito com a reunião, então terminar assim deve ser muito decepcionante.","fr":"Jamshid : Vous vous êtes beaucoup inquiété pour la réunion, alors que ça se termine ainsi doit être vraiment décevant.","ta":"ஜம்ஷித்: நீங்கள் கூட்டத்தைப் பற்றி நிறைய கவலைப்பட்டீர்கள், அதனால் இப்படி முடிந்தது மிகவும் ஏமாற்றமாக இருக்கும்." },
  "문장 ① 저는 평소에 직설적으로 말하는 편인데 상대방이 가끔 상처를 받아요.": { "bn":"আমি সাধারণত সরাসরি কথা বলি, তাই মাঝেমধ্যে অন্যজন আঘাত পায়।","ru":"Обычно я говорю прямо, поэтому иногда собеседнику бывает обидно.","he":"אני נוטה לדבר בגלוי בדרך כלל, ולכן לפעמים הצד השני נפגע.","ms":"Saya biasanya bercakap secara berterus-terang, jadi kadangkala orang lain terguris hati.","vi":"Tôi thường nói thẳng nên đôi khi người kia bị tổn thương.","id":"Saya biasanya berbicara secara blak-blakan, jadi kadang lawan bicara merasa tersinggung.","si":"මම සාමාන්‍යයෙන් කෙළින්ම කතා කරන නිසා, සමහර වෙලාවට අනිත් පුද්ගලයාට හිත රිදෙනවා.","pt":"Costumo falar de forma direta, então às vezes a outra pessoa se magoa.","fr":"J'ai tendance à parler franchement d'habitude, alors parfois l'autre personne est blessée.","ta":"நான் வழக்கமாக நேரடியாகப் பேசுவதால், சில நேரங்களில் மற்றவர் மனம் புண்படுகிறார்." },
  "문장 ② 억양이 부자연스러워서 제가 말할 때마다 사람들이 고향이 어디냐고 물어봐요.": { "bn":"আমার স্বরভঙ্গি স্বাভাবিক নয়, তাই যখনই কথা বলি লোকজন জিজ্ঞেস করে আমার দেশ কোথায়।","ru":"У меня неестественная интонация, поэтому, когда я говорю, люди спрашивают, откуда я родом.","he":"האינטונציה שלי לא טבעית, ולכן בכל פעם שאני מדבר אנשים שואלים מאיפה אני.","ms":"Intonasi saya tidak semula jadi, jadi setiap kali saya bercakap orang bertanya dari mana kampung halaman saya.","vi":"Ngữ điệu của tôi không tự nhiên nên mỗi khi tôi nói, mọi người hỏi quê tôi ở đâu.","id":"Intonasi saya tidak alami, jadi setiap kali saya berbicara orang bertanya dari mana asal saya.","si":"මගේ ස්වර රටාව ස්වාභාවික නැති නිසා, මම කතා කරන හැම වෙලාවකම මිනිස්සු මගේ ගම කොහෙද කියලා අහනවා.","pt":"Minha entonação é pouco natural, então sempre que falo as pessoas perguntam de onde eu sou.","fr":"Mon intonation n'est pas naturelle, alors chaque fois que je parle, les gens me demandent d'où je viens.","ta":"என் ஒலியேற்ற இறக்கம் இயற்கையாக இல்லாததால், நான் பேசும் ஒவ்வொரு முறையும் மக்கள் என் சொந்த ஊர் எங்கே என்று கேட்கிறார்கள்." },
  "문장 ③ 격식을 차려서 말해야 하는 상황에서 어떻게 말해야 할지 잘 모를 때가 많아요.": { "bn":"যেখানে আনুষ্ঠানিকভাবে কথা বলতে হয়, সেখানে কীভাবে বলব তা প্রায়ই বুঝতে পারি না।","ru":"В ситуациях, когда нужно говорить официально, я часто не знаю, как говорить.","he":"במצבים שבהם אני צריך לדבר בצורה רשמית, לעיתים קרובות אני לא יודע איך לדבר.","ms":"Dalam situasi yang memerlukan pertuturan formal, saya selalu tidak tahu bagaimana harus bercakap.","vi":"Trong những tình huống phải nói trang trọng, tôi thường không biết mình nên nói thế nào.","id":"Dalam situasi yang mengharuskan berbicara formal, saya sering tidak tahu bagaimana harus berbicara.","si":"විධිමත් ලෙස කතා කළ යුතු අවස්ථාවලදී, කොහොම කතා කරන්නද කියලා මට බොහෝ විට තේරෙන්නේ නෑ.","pt":"Em situações em que preciso falar formalmente, muitas vezes não sei como devo falar.","fr":"Dans les situations où je dois parler de manière formelle, souvent je ne sais pas comment je devrais parler.","ta":"முறையாகப் பேச வேண்டிய சூழல்களில், நான் எப்படிப் பேச வேண்டும் என்று பல நேரங்களில் தெரியாமல் இருக்கிறேன்." },
  "③ 안젤라 씨는 때와 장소에 맞게 말할 수 없었다.": { "bn":"আঞ্জেলা সময় ও স্থান অনুযায়ী উপযুক্তভাবে কথা বলতে পারেননি।","ru":"Анджела не смогла говорить уместно для времени и места.","he":"אנג'לה לא הצליחה לדבר באופן שמתאים לזמן ולמקום.","ms":"Angela tidak dapat bercakap dengan sesuai mengikut masa dan tempat.","vi":"Angela đã không thể nói cho phù hợp với thời gian và địa điểm.","id":"Angela tidak dapat berbicara secara sesuai dengan waktu dan tempat.","si":"ඇන්ජෙලාට වේලාවට සහ ස්ථානයට ගැලපෙන ලෙස කතා කරන්න බැරි වුණා.","pt":"Angela não conseguiu falar de forma apropriada ao tempo e ao lugar.","fr":"Angela n'a pas pu parler de manière adaptée au moment et au lieu.","ta":"ஏஞ்சலாவால் நேரத்திற்கும் இடத்திற்கும் ஏற்றவாறு பேச முடியவில்லை." },
  "자식에 대한 학부모들의 교육열이 점점 높아지고 있다.": { "bn":"সন্তানদের প্রতি অভিভাবকদের শিক্ষা-আগ্রহ ক্রমশ বাড়ছে।","ru":"Стремление родителей дать детям образование постепенно растёт.","he":"הלהט החינוכי של ההורים כלפי ילדיהם הולך וגובר בהדרגה.","ms":"Semangat pendidikan ibu bapa terhadap anak-anak semakin meningkat.","vi":"Nhiệt huyết giáo dục của cha mẹ dành cho con cái đang dần tăng lên.","id":"Semangat pendidikan orang tua terhadap anak-anak semakin meningkat.","si":"දරුවන් සම්බන්ධයෙන් දෙමාපියන්ගේ අධ්‍යාපන උනන්දුව ක්‍රමයෙන් ඉහළ යමින් පවතී.","pt":"O entusiasmo educacional dos pais pelos filhos vem aumentando gradualmente.","fr":"L'ardeur des parents pour l'éducation de leurs enfants augmente peu à peu.","ta":"குழந்தைகள் மீதான பெற்றோரின் கல்வி ஆர்வம் படிப்படியாக அதிகரித்து வருகிறது." },
  "한국은 입시 경쟁도 치열하고 교육열도 높은 것 같아요.": { "bn":"মনে হয় কোরিয়ায় ভর্তি পরীক্ষার প্রতিযোগিতা তীব্র এবং শিক্ষা-আগ্রহও অনেক বেশি।","ru":"Кажется, в Корее конкуренция на вступительных экзаменах жёсткая, да и стремление к образованию высокое.","he":"נראה שבקוריאה התחרות בבחינות הכניסה עזה וגם הלהט החינוכי גבוה.","ms":"Nampaknya di Korea persaingan peperiksaan kemasukan sengit dan semangat pendidikan juga tinggi.","vi":"Có vẻ như ở Hàn Quốc, cạnh tranh thi tuyển rất gay gắt và nhiệt huyết giáo dục cũng cao.","id":"Sepertinya di Korea persaingan ujian masuk sangat ketat dan semangat pendidikannya juga tinggi.","si":"කොරියාවේ ඇතුළත් වීමේ විභාග තරගය දරුණු වගේම අධ්‍යාපන උනන්දුවත් ඉහළයි වගේ.","pt":"Parece que na Coreia a competição nos exames de admissão é acirrada e o entusiasmo educacional também é alto.","fr":"Il semble qu'en Corée la concurrence aux examens d'entrée soit féroce et que l'ardeur pour l'éducation soit également forte.","ta":"கொரியாவில் நுழைவுத் தேர்வுப் போட்டி கடுமையாகவும், கல்வி ஆர்வமும் அதிகமாகவும் இருப்பதாகத் தெரிகிறது." }
}
