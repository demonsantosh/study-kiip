{
  "혼자 살다": { "ne":"एक्लै बस्नु","ta":"தனியாக வாழ்தல்" },
  "아이를 입양하다": { "ne":"बच्चा गोद लिनु","ta":"குழந்தையைத் தத்தெடுத்தல்" },
  "주말부부로 지내다": { "ne":"सप्ताहन्त दम्पती भएर बस्नु","ta":"வார இறுதி தம்பதியாக வாழ்தல்" },
  "한쪽 부모와 살다": { "ne":"एक जना अभिभावकसँग बस्नु","ta":"ஒரு பெற்றோருடன் வாழ்தல்" },
  "가족의 형태와 특징": { "ne":"परिवारको स्वरूप र विशेषता","ta":"குடும்பத்தின் வடிவங்களும் பண்புகளும்" },
  "매일 가계부를 써요?": { "ne":"के तपाईं हरेक दिन घरखर्चको हिसाब लेख्नुहुन्छ?","ta":"நீங்கள் தினமும் வீட்டுச் செலவுக் கணக்கு எழுதுகிறீர்களா?" },
  "육아 휴직을 냈어요?": { "ne":"के तपाईंले शिशु स्याहार बिदा लिनुभयो?","ta":"நீங்கள் குழந்தை பராமரிப்பு விடுப்பு எடுத்தீர்களா?" },
  "가족의 특징에 대해 말하기": { "ne":"परिवारका विशेषताबारे कुरा गर्ने","ta":"குடும்பத்தின் பண்புகள் பற்றிப் பேசுதல்" },
  "제이슨: 이링 씨는 어때요?": { "ne":"जेसन: इलिङ जी, तपाईंलाई चाहिँ कस्तो छ?","ta":"ஜேசன்: இலிங், உங்களுக்கு எப்படி?" },
  "2️⃣ 가족 관계가 평등해요.": { "ne":"पारिवारिक सम्बन्ध समान हुन्छ।","ta":"குடும்ப உறவுகள் சமமாக இருக்கும்." },
  "3️⃣ 경제적인 부담이 적어요.": { "ne":"आर्थिक भार कम हुन्छ।","ta":"பொருளாதாரச் சுமை குறைவாக இருக்கும்." },
  "말을 곱게 하세요.": { "bn":"সুন্দর করে কথা বলুন।","ru":"Пожалуйста, говорите вежливо.","he":"דברו יפה, בבקשה.","ms":"Tolong bercakap dengan sopan.","vi":"Xin hãy nói năng nhẹ nhàng.","id":"Tolong berbicara dengan santun.","si":"කරුණාකර මුදුවට කතා කරන්න.","pt":"Por favor, fale com gentileza.","fr":"Parlez gentiment, s'il vous plaît.","ta":"தயவு செய்து இனிமையாகப் பேசுங்கள்." },
  "① 언어가 파괴된다.": { "bn":"ভাষা ধ্বংস হয়ে যায়।","ru":"Язык разрушается.","he":"השפה נהרסת.","ms":"Bahasa menjadi rosak.","vi":"Ngôn ngữ bị phá hoại.","id":"Bahasa menjadi rusak.","si":"භාෂාව විනාශ වේ.","pt":"A língua é destruída.","fr":"La langue se dégrade.","ta":"மொழி சிதைந்து போகிறது." },
  "③ 혼란을 일으킨다.": { "bn":"এগুলো বিভ্রান্তি সৃষ্টি করে।","ru":"Они вызывают путаницу.","he":"הם גורמים לבלבול.","ms":"Ia menyebabkan kekeliruan.","vi":"Chúng gây ra sự nhầm lẫn.","id":"Hal itu menimbulkan kebingungan.","si":"ඒවා ව්‍යාකූලත්වය ඇති කරයි.","pt":"Elas causam confusão.","fr":"Elles provoquent la confusion.","ta":"அவை குழப்பத்தை ஏற்படுத்துகின்றன." },
  "② 의미가 확실하지 않다.": { "bn":"অর্থ স্পষ্ট নয়।","ru":"Значение неясно.","he":"המשמעות אינה ברורה.","ms":"Maknanya tidak jelas.","vi":"Nghĩa không rõ ràng.","id":"Maknanya tidak jelas.","si":"තේරුම පැහැදිලි නැත.","pt":"O significado não é claro.","fr":"Le sens n'est pas clair.","ta":"பொருள் தெளிவாக இல்லை." },
  "③ 쉽게 공감할 수 있다.": { "bn":"সহজে সহমর্মিতা অনুভব করা যায়।","ru":"Ими легко проникнуться.","he":"קל להזדהות איתם.","ms":"Mudah untuk memahami dan bersimpati.","vi":"Có thể dễ dàng đồng cảm.","id":"Mudah untuk berempati.","si":"පහසුවෙන් සංවේදනය කළ හැක.","pt":"É fácil identificar-se com elas.","fr":"On peut facilement s'y identifier.","ta":"எளிதாக ஒத்துணர முடியும்." },
  "④ 젊은 세대와 소통이 잘된다.": { "bn":"তরুণ প্রজন্মের সঙ্গে যোগাযোগ ভালো হয়।","ru":"Хорошо налаживается общение с молодым поколением.","he":"התקשורת עם הדור הצעיר מתנהלת היטב.","ms":"Komunikasi dengan generasi muda berjalan lancar.","vi":"Việc giao tiếp với thế hệ trẻ diễn ra tốt đẹp.","id":"Komunikasi dengan generasi muda berjalan lancar.","si":"තරුණ පරම්පරාව සමඟ සන්නිවේදනය හොඳින් සිදු වේ.","pt":"A comunicação com a geração mais jovem funciona bem.","fr":"La communication avec la jeune génération se passe bien.","ta":"இளைய தலைமுறையுடன் தொடர்பு நன்றாக நடக்கிறது." },
  "신랑과 신부는 결혼해요.": { "bn":"বর ও কনে বিয়ে করে।","ru":"Жених и невеста женятся.","he":"החתן והכלה מתחתנים.","ms":"Pengantin lelaki dan pengantin perempuan berkahwin.","vi":"Chú rể và cô dâu kết hôn.","id":"Pengantin pria dan pengantin wanita menikah.","si":"මනාලයා සහ මනාලිය විවාහ වේ.","pt":"O noivo e a noiva se casam.","fr":"Le marié et la mariée se marient.","ta":"மணமகனும் மணமகளும் திருமணம் செய்கிறார்கள்." },
  "조문객은 조의금을 내요.": { "bn":"শোকার্ত অতিথিরা সমবেদনার অর্থ দেন।","ru":"Пришедшие на похороны дают деньги соболезнования.","he":"המנחמים נותנים דמי תנחומים.","ms":"Pelawat takziah memberikan wang takziah.","vi":"Người đến viếng đưa tiền phúng viếng.","id":"Pelayat memberikan uang duka.","si":"ශෝකය ප්‍රකාශ කරන්නෝ ශෝක මුදල් ලබා දෙති.","pt":"Os enlutados dão dinheiro de condolências.","fr":"Les personnes venues présenter leurs condoléances donnent de l'argent.","ta":"இரங்கல் தெரிவிக்க வருபவர்கள் இரங்கல் பணம் கொடுக்கிறார்கள்." },
  "사회자는 결혼식을 진행해요.": { "bn":"সঞ্চালক বিবাহ অনুষ্ঠান পরিচালনা করেন।","ru":"Ведущий проводит свадебную церемонию.","he":"המנחה מנחה את טקס החתונה.","ms":"Juruacara mengendalikan majlis perkahwinan.","vi":"Người dẫn chương trình điều hành lễ cưới.","id":"Pembawa acara memandu upacara pernikahan.","si":"උත්සව මෙහෙයවන්නා විවාහ උත්සවය මෙහෙයවයි.","pt":"O mestre de cerimônias conduz o casamento.","fr":"Le maître de cérémonie anime le mariage.","ta":"நிகழ்ச்சித் தொகுப்பாளர் திருமண விழாவை நடத்துகிறார்." },
  "이 사람들은 결혼식에 갔어요.": { "bn":"এই লোকেরা একটি বিবাহ অনুষ্ঠানে গিয়েছিল।","ru":"Эти люди пошли на свадьбу.","he":"האנשים האלה הלכו לחתונה.","ms":"Orang-orang ini pergi ke majlis perkahwinan.","vi":"Những người này đã đi dự đám cưới.","id":"Orang-orang ini pergi ke pesta pernikahan.","si":"මේ අය විවාහ උත්සවයකට ගියා.","pt":"Estas pessoas foram a um casamento.","fr":"Ces gens sont allés à un mariage.","ta":"இந்த மக்கள் ஒரு திருமண விழாவுக்குச் சென்றார்கள்." },
  "사람은 누구나 늙기 마련이에요.": { "bn":"প্রত্যেক মানুষই বৃদ্ধ হতে বাধ্য।","ru":"Каждый человек неизбежно стареет.","he":"כל אדם מזדקן בהכרח.","ms":"Setiap orang pasti akan menjadi tua.","vi":"Ai rồi cũng phải già đi.","id":"Setiap orang pasti menjadi tua.","si":"ඕනෑම කෙනෙකු මහලු වීම නියතයි.","pt":"Todo mundo está fadado a envelhecer.","fr":"Tout le monde finit forcément par vieillir.","ta":"எவரும் வயதாகத்தான் வேண்டும்." },
  "부모의 입장에서는 이해가 돼요.": { "bn":"বাবা-মায়ের দৃষ্টিকোণ থেকে এটা বোঝা যায়।","ru":"С точки зрения родителей это можно понять.","he":"מנקודת המבט של ההורים אפשר להבין את זה.","ms":"Dari sudut pandang ibu bapa, ia boleh difahami.","vi":"Đứng từ lập trường của cha mẹ thì có thể hiểu được.","id":"Dari sudut pandang orang tua, hal itu bisa dimengerti.","si":"දෙමාපියන්ගේ දෘෂ්ටිකෝණයෙන් එය තේරුම් ගත හැක.","pt":"Do ponto de vista dos pais, é compreensível.","fr":"Du point de vue des parents, c'est compréhensible.","ta":"பெற்றோரின் பார்வையில் இதைப் புரிந்துகொள்ள முடியும்." },
  "② 왜 환경 보호를 해야 해요?": { "bn":"আমাদের কেন পরিবেশ রক্ষা করতে হবে?","ru":"Почему мы должны защищать окружающую среду?","he":"למה צריך להגן על הסביבה?","ms":"Mengapa kita perlu melindungi alam sekitar?","vi":"Tại sao chúng ta phải bảo vệ môi trường?","id":"Mengapa kita harus melindungi lingkungan?","si":"අපි පරිසරය ආරක්ෂා කළ යුත්තේ ඇයි?","pt":"Por que devemos proteger o meio ambiente?","fr":"Pourquoi doit-on protéger l'environnement ?","ta":"நாம் ஏன் சுற்றுச்சூழலைப் பாதுகாக்க வேண்டும்?" },
  "동생의 키가 엄청 크다면서요?": { "bn":"শুনলাম তোমার ছোট ভাই/বোন নাকি খুব লম্বা?","ru":"Говорят, твой младший брат/сестра очень высокий?","he":"שמעתי שאח/אחות הקטן/ה שלך ממש גבוה/ה?","ms":"Katanya adik awak sangat tinggi?","vi":"Nghe nói em của bạn cao lắm phải không?","id":"Katanya adikmu tinggi sekali, ya?","si":"ඔයාගේ නංගී/මල්ලී ගොඩක් උසයි කියලා ඇහුවා, ඇත්තද?","pt":"Ouvi dizer que seu irmão/irmã mais novo(a) é bem alto(a)?","fr":"Il paraît que ton cadet/ta cadette est très grand(e) ?","ta":"உங்கள் தம்பி/தங்கை ரொம்ப உயரமாம், அப்படித்தானே?" },
  "발 없는 말이 천 리 간다.": { "bn":"পা ছাড়া কথা হাজার লি পথ যায় (গুজব দ্রুত ছড়ায়)।","ru":"Слова без ног проходят тысячу ли (слухи расходятся быстро и далеко).","he":"מילים בלי רגליים עוברות אלף לי (שמועות מתפשטות מהר ורחוק).","ms":"Perkataan tanpa kaki menempuh seribu li (khabar angin tersebar cepat dan jauh).","vi":"Lời nói không chân đi ngàn dặm (tin đồn lan nhanh và xa).","id":"Perkataan tanpa kaki menempuh seribu li (kabar tersebar cepat dan jauh).","si":"කකුල් නැති වචන දහසක් යොදුන් යයි (කටකතා වේගයෙන් පැතිරෙයි).","pt":"Palavras sem pés percorrem mil li (os boatos se espalham rápido e longe).","fr":"Les paroles sans pieds parcourent mille li (les rumeurs se propagent vite et loin).","ta":"கால் இல்லாத சொல் ஆயிரம் மைல் செல்லும் (வதந்தி வேகமாகப் பரவும்)." },
  "호랑이도 제 말 하면 온다.": { "bn":"বাঘের কথা বললে বাঘও এসে হাজির হয় (যার কথা বলি সে-ই এসে পড়ে)।","ru":"Даже тигр приходит, когда о нём говорят (лёгок на помине).","he":"אפילו נמר מגיע כשמדברים עליו (מזכירים מישהו והוא מופיע).","ms":"Harimau pun datang apabila diperkatakan (sebut seseorang, dia pun muncul).","vi":"Nhắc đến hổ thì hổ cũng đến (nhắc ai người ấy tới).","id":"Harimau pun datang jika dibicarakan (baru disebut, orangnya muncul).","si":"කතා කළොත් කොටියාත් එයි (කෙනෙකු ගැන කිව්වම එයා පැමිණේ).","pt":"Até o tigre aparece quando se fala dele (falou da pessoa, ela aparece).","fr":"Même le tigre vient quand on parle de lui (quand on parle de quelqu'un, il apparaît).","ta":"புலியைப் பற்றிப் பேசினாலும் அது வந்துவிடும் (யாரைப் பற்றிப் பேசுகிறோமோ அவர் வந்துவிடுவார்)." },
  "국제기구란 무엇입니까?": { "bn":"আন্তর্জাতিক সংস্থা কী?","ru":"Что такое международная организация?","he":"מהו ארגון בין-לאומי?","ms":"Apakah itu organisasi antarabangsa?","vi":"Tổ chức quốc tế là gì?","id":"Apa itu organisasi internasional?","si":"ජාත්‍යන්තර සංවිධානයක් යනු කුමක්ද?","pt":"O que é uma organização internacional?","fr":"Qu'est-ce qu'une organisation internationale ?","ta":"சர்வதேச அமைப்பு என்றால் என்ன?" }
}
