{
  "이 사람들의 언어생활이 어떨 것 같아요?": { "ne":"यी मानिसहरूको भाषिक जीवन कस्तो होला जस्तो लाग्छ?","bn":"এই মানুষদের ভাষা-জীবন কেমন বলে মনে হয়?","ru":"Как вы думаете, какова языковая жизнь этих людей?","he":"איך נראים חיי השפה של האנשים האלה, לדעתכם?","ms":"Pada pendapat anda, bagaimanakah kehidupan bahasa orang-orang ini?","vi":"Bạn nghĩ đời sống ngôn ngữ của những người này như thế nào?","id":"Menurut Anda, seperti apa kehidupan berbahasa orang-orang ini?","si":"මේ මිනිසුන්ගේ භාෂා ජීවිතය කෙබඳුදැයි ඔබ සිතන්නේ කුමක්ද?","pt":"Como você acha que é a vida linguística dessas pessoas?","fr":"Selon vous, comment est la vie linguistique de ces personnes ?","ta":"இந்த மக்களின் மொழி வாழ்க்கை எப்படி இருக்கும் என்று நினைக்கிறீர்கள்?" },
  "여러분은 한국어로 대화할 때 어려움이 있어요?": { "ne":"तपाईंलाई कोरियन भाषामा कुराकानी गर्दा कठिनाइ हुन्छ?","bn":"আপনাদের কি কোরিয়ান ভাষায় কথা বলার সময় অসুবিধা হয়?","ru":"Испытываете ли вы трудности при общении на корейском языке?","he":"האם יש לכם קושי כשאתם משוחחים בקוריאנית?","ms":"Adakah anda menghadapi kesukaran ketika berbual dalam bahasa Korea?","vi":"Các bạn có gặp khó khăn khi trò chuyện bằng tiếng Hàn không?","id":"Apakah Anda mengalami kesulitan saat berbicara dalam bahasa Korea?","si":"කොරියානු භාෂාවෙන් කතා කරන විට ඔබට අපහසුතා තිබේද?","pt":"Vocês têm dificuldades ao conversar em coreano?","fr":"Avez-vous des difficultés lorsque vous conversez en coréen ?","ta":"நீங்கள் கொரிய மொழியில் உரையாடும்போது சிரமம் ஏற்படுகிறதா?" },
  "이 단원은 올바른 언어생활과 외국인이 한국어를 쓸 때 겪는 어려움을 다룹니다.": { "ne":"यो एकाइले सही भाषिक व्यवहार र विदेशीहरूले कोरियन प्रयोग गर्दा भोग्ने कठिनाइहरूबारे चर्चा गर्छ।","bn":"এই অধ্যায়টি সঠিক ভাষা ব্যবহার এবং বিদেশিরা কোরিয়ান ব্যবহার করার সময় যে অসুবিধার সম্মুখীন হয় তা নিয়ে আলোচনা করে।","ru":"В этом разделе рассматриваются правильное использование языка и трудности, с которыми сталкиваются иностранцы при использовании корейского.","he":"יחידה זו עוסקת בשימוש נכון בשפה ובקשיים שזרים חווים כשהם משתמשים בקוריאנית.","ms":"Unit ini membincangkan penggunaan bahasa yang betul serta kesukaran yang dihadapi orang asing ketika menggunakan bahasa Korea.","vi":"Bài học này đề cập đến việc sử dụng ngôn ngữ đúng đắn và những khó khăn mà người nước ngoài gặp phải khi sử dụng tiếng Hàn.","id":"Unit ini membahas penggunaan bahasa yang benar dan kesulitan yang dihadapi orang asing saat menggunakan bahasa Korea.","si":"මෙම ඒකකය නිවැරදි භාෂා භාවිතය සහ විදේශිකයන් කොරියානු භාවිතා කරන විට මුහුණ දෙන දුෂ්කරතා ගැන සාකච්ඡා කරයි.","pt":"Esta unidade trata do uso correto da língua e das dificuldades que os estrangeiros enfrentam ao usar o coreano.","fr":"Cette unité traite du bon usage de la langue et des difficultés que rencontrent les étrangers lorsqu'ils utilisent le coréen.","ta":"இந்தப் பாடம் சரியான மொழிப் பயன்பாடு மற்றும் வெளிநாட்டவர் கொரிய மொழியைப் பயன்படுத்தும்போது எதிர்கொள்ளும் சிரமங்களைப் பற்றி பேசுகிறது." },
  "도입 그림은 한국어 대화 중 \"못 알아듣는 상황\"(다시 네?)을 보여 주며 주제를 안내합니다.": { "ne":"परिचय चित्रले कोरियन कुराकानीका बेला 'बुझ्न नसकिने अवस्था' (फेरि, हैन?) देखाउँदै विषय परिचय गराउँछ।","bn":"সূচনা ছবিটি কোরিয়ান কথোপকথনের সময় 'বুঝতে না পারার পরিস্থিতি' (আবার বলুন?) দেখিয়ে বিষয়টি পরিচয় করিয়ে দেয়।","ru":"Вводная иллюстрация показывает «ситуацию непонимания» (Что, простите?) во время разговора на корейском и вводит тему.","he":"איור הפתיחה מציג 'מצב של אי-הבנה' (סליחה, מה?) במהלך שיחה בקוריאנית ומציג את הנושא.","ms":"Gambar pengenalan menunjukkan 'situasi tidak memahami' (Maaf, apa?) semasa perbualan Korea dan memperkenalkan topik.","vi":"Hình minh họa mở đầu cho thấy 'tình huống không hiểu' (Xin lỗi, gì cơ?) trong khi trò chuyện bằng tiếng Hàn và giới thiệu chủ đề.","id":"Gambar pembuka menunjukkan 'situasi tidak mengerti' (Maaf, apa?) saat percakapan dalam bahasa Korea dan memperkenalkan topik.","si":"හැඳින්වීමේ රූපය කොරියානු සංවාදයක් අතරතුර 'තේරුම් නොගන්නා තත්ත්වයක්' (නැවත, ඇයි?) පෙන්වා මාතෘකාව හඳුන්වා දෙයි.","pt":"A imagem introdutória mostra uma 'situação de não entender' (Como? Desculpe?) durante uma conversa em coreano e apresenta o tema.","fr":"L'image d'introduction montre une « situation d'incompréhension » (Pardon ?) lors d'une conversation en coréen et présente le sujet." },
  "여러분은 한국어로 말할 때 어떤 어려움이 있어요?": { "ne":"तपाईंलाई कोरियन बोल्दा कस्ता कठिनाइहरू हुन्छन्?","bn":"কোরিয়ান ভাষায় কথা বলার সময় আপনাদের কী ধরনের অসুবিধা হয়?","ru":"Какие трудности возникают у вас, когда вы говорите по-корейски?","he":"אילו קשיים יש לכם כשאתם מדברים קוריאנית?","ms":"Apakah kesukaran yang anda hadapi ketika bertutur dalam bahasa Korea?","vi":"Các bạn gặp những khó khăn gì khi nói tiếng Hàn?","id":"Kesulitan apa yang Anda hadapi saat berbicara bahasa Korea?","si":"කොරියානු භාෂාවෙන් කතා කරන විට ඔබට කුමන අපහසුතා තිබේද?","pt":"Que dificuldades vocês têm ao falar coreano?","fr":"Quelles difficultés avez-vous lorsque vous parlez coréen ?" },
  "아직 맞춤법이 많이 틀리는데 맞춤법에 맞게 잘 쓰고 싶어요": { "ne":"मेरो हिज्जे अझै धेरै गल्ती हुन्छ, तर हिज्जे अनुसार राम्ररी लेख्न चाहन्छु।","bn":"আমার এখনও অনেক বানান ভুল হয়, কিন্তু আমি বানান নিয়ম অনুযায়ী ভালোভাবে লিখতে চাই।","ru":"Я всё ещё делаю много орфографических ошибок, но хочу писать правильно, по правилам.","he":"אני עדיין עושה הרבה שגיאות כתיב, אבל אני רוצה לכתוב נכון לפי כללי הכתיב.","ms":"Ejaan saya masih banyak salah, tetapi saya mahu menulis dengan betul mengikut ejaan.","vi":"Tôi vẫn còn sai chính tả nhiều, nhưng tôi muốn viết đúng theo quy tắc chính tả.","id":"Ejaan saya masih banyak yang salah, tetapi saya ingin menulis dengan benar sesuai ejaan.","si":"මගේ අක්ෂර වින්‍යාසය තවම බොහෝ වැරදෙනවා, නමුත් මට අක්ෂර වින්‍යාසයට අනුව හරියට ලියන්න ඕනෑ.","pt":"Eu ainda erro muito a ortografia, mas quero escrever corretamente conforme as regras.","fr":"Je fais encore beaucoup de fautes d'orthographe, mais je veux écrire correctement selon les règles." },
  "아직 맞춤법이 많이 틀리는데 맞춤법에 맞게 잘 쓰고 싶어요.": { "bn":"আমার এখনও অনেক বানান ভুল হয়, কিন্তু আমি বানান নিয়ম অনুযায়ী ভালোভাবে লিখতে চাই।","ru":"Я всё ещё делаю много орфографических ошибок, но хочу писать правильно, по правилам.","he":"אני עדיין עושה הרבה שגיאות כתיב, אבל אני רוצה לכתוב נכון לפי כללי הכתיב.","ms":"Ejaan saya masih banyak salah, tetapi saya mahu menulis dengan betul mengikut ejaan.","vi":"Tôi vẫn còn sai chính tả nhiều, nhưng tôi muốn viết đúng theo quy tắc chính tả.","id":"Ejaan saya masih banyak yang salah, tetapi saya ingin menulis dengan benar sesuai ejaan.","si":"මගේ අක්ෂර වින්‍යාසය තවම බොහෝ වැරදෙනවා, නමුත් මට අක්ෂර වින්‍යාසයට අනුව හරියට ලියන්න ඕනෑ.","pt":"Eu ainda erro muito a ortografia, mas quero escrever corretamente conforme as regras.","fr":"Je fais encore beaucoup de fautes d'orthographe, mais je veux écrire correctement selon les règles." },
  "제가 의도한 대로 말이 잘 안 나올 때가 많아요": { "ne":"मैले सोचेजस्तै शब्दहरू राम्ररी ननिस्कने बेला धेरै हुन्छ।","bn":"আমি যেভাবে চাই সেভাবে কথা বেরিয়ে আসে না, এমন সময় প্রায়ই হয়।","ru":"Часто бывает, что слова не выходят так, как я задумал.","he":"לעתים קרובות המילים לא יוצאות כפי שהתכוונתי.","ms":"Selalu ada masa apabila kata-kata tidak keluar seperti yang saya maksudkan.","vi":"Nhiều khi lời nói không thốt ra được như tôi đã định.","id":"Sering kali kata-kata tidak keluar seperti yang saya maksudkan.","si":"මම හිතපු විදිහට වචන හරියට එළියට නොඑන අවස්ථා බොහෝයි.","pt":"Muitas vezes as palavras não saem como eu pretendia.","fr":"Il arrive souvent que les mots ne sortent pas comme je le voulais." },
  "제가 의도한 대로 말이 잘 안 나올 때가 많아요.": { "bn":"আমি যেভাবে চাই সেভাবে কথা বেরিয়ে আসে না, এমন সময় প্রায়ই হয়।","ru":"Часто бывает, что слова не выходят так, как я задумал.","he":"לעתים קרובות המילים לא יוצאות כפי שהתכוונתי.","ms":"Selalu ada masa apabila kata-kata tidak keluar seperti yang saya maksudkan.","vi":"Nhiều khi lời nói không thốt ra được như tôi đã định.","id":"Sering kali kata-kata tidak keluar seperti yang saya maksudkan.","si":"මම හිතපු විදිහට වචන හරියට එළියට නොඑන අවස්ථා බොහෝයි.","pt":"Muitas vezes as palavras não saem como eu pretendia.","fr":"Il arrive souvent que les mots ne sortent pas comme je le voulais." },
  "올바른 언어생활을 위해 지켜야 할 것": { "bn":"সঠিক ভাষা ব্যবহারের জন্য যা মেনে চলতে হবে","ru":"Что нужно соблюдать для правильного использования языка","he":"מה שיש לשמור עליו לשם שימוש נכון בשפה","ms":"Perkara yang perlu dipatuhi untuk penggunaan bahasa yang betul","vi":"Những điều cần tuân thủ để sử dụng ngôn ngữ đúng đắn","id":"Hal-hal yang harus dipatuhi untuk penggunaan bahasa yang benar","si":"නිවැරදි භාෂා භාවිතය සඳහා පිළිපැදිය යුතු දේ","pt":"O que se deve seguir para o uso correto da língua","fr":"Ce qu'il faut respecter pour un bon usage de la langue" },
  "한국어로 말할 때의 어려움": { "bn":"কোরিয়ান ভাষায় কথা বলার সময়ের অসুবিধা","ru":"Трудности при разговоре на корейском языке","he":"קשיים בעת דיבור בקוריאנית","ms":"Kesukaran ketika bertutur dalam bahasa Korea","vi":"Khó khăn khi nói tiếng Hàn","id":"Kesulitan saat berbicara dalam bahasa Korea","si":"කොරියානු භාෂාවෙන් කතා කරන විට ඇති අපහසුතා","pt":"Dificuldades ao falar coreano","fr":"Difficultés lorsqu'on parle coréen","ta":"கொரிய மொழியில் பேசும்போது ஏற்படும் சிரமங்கள்" },
  "자주 쓰는 표현: 동문서답하다 = 묻는 말과 상관없는 엉뚱한 대답 → 대화 단절의 대표 예.": { "ne":"बारम्बार प्रयोग हुने अभिव्यक्ति: 동문서답하다 = सोधिएको कुरासँग सम्बन्धित नभएको बेतुकको जवाफ → कुराकानी टुट्ने प्रतिनिधि उदाहरण।","bn":"প্রায়ই ব্যবহৃত অভিব্যক্তি: 동문서답하다 = প্রশ্নের সঙ্গে সম্পর্কহীন উদ্ভট উত্তর → কথোপকথন ভেঙে যাওয়ার প্রতিনিধিত্বমূলক উদাহরণ।","ru":"Часто используемое выражение: 동문서답하다 = нелепый ответ, не связанный с вопросом → типичный пример прерывания разговора.","he":"ביטוי נפוץ: 동문서답하다 = תשובה מופרכת שאינה קשורה לשאלה → דוגמה אופיינית לניתוק בשיחה.","ms":"Ungkapan yang kerap digunakan: 동문서답하다 = jawapan yang tidak berkaitan dengan soalan → contoh tipikal komunikasi terputus.","vi":"Cách diễn đạt thường dùng: 동문서답하다 = câu trả lời vô nghĩa không liên quan đến câu hỏi → ví dụ tiêu biểu của sự gián đoạn hội thoại.","id":"Ungkapan yang sering dipakai: 동문서답하다 = jawaban ngawur yang tidak berkaitan dengan pertanyaan → contoh khas putusnya percakapan.","si":"නිතර භාවිත වන ප්‍රකාශනය: 동문서답하다 = ප්‍රශ්නයට සම්බන්ධ නැති අමුතු පිළිතුරක් → සංවාදය බිඳ වැටීමේ නියෝජිත උදාහරණය.","pt":"Expressão de uso frequente: 동문서답하다 = uma resposta absurda sem relação com a pergunta → exemplo típico de ruptura na conversa.","fr":"Expression fréquente : 동문서답하다 = une réponse absurde sans rapport avec la question → exemple typique de rupture de la conversation.","ta":"அடிக்கடி பயன்படுத்தப்படும் சொற்றொடர்: 동문서답하다 = கேள்விக்குத் தொடர்பில்லாத பொருத்தமற்ற பதில் → உரையாடல் முறிவுக்கான பொதுவான உதாரணம்." },
  "의도하지 않은 어떤 일이 결국 일어났음을 나타낸다": { "ne":"उद्देश्य नराखिएको कुनै कुरा अन्ततः भयो भन्ने जनाउँछ।","bn":"অনিচ্ছাকৃত কোনো ঘটনা শেষ পর্যন্ত ঘটে গেছে তা বোঝায়।","ru":"Указывает на то, что некое непреднамеренное событие в итоге произошло.","he":"מציין שאירוע כלשהו שלא התכוונו אליו התרחש בסופו של דבר.","ms":"Menunjukkan bahawa sesuatu yang tidak disengajakan akhirnya berlaku.","vi":"Diễn tả rằng một việc ngoài ý muốn cuối cùng đã xảy ra.","id":"Menunjukkan bahwa suatu hal yang tidak disengaja akhirnya terjadi.","si":"අදහස් නොකළ යම් දෙයක් අවසානයේ සිදු වූ බව දක්වයි.","pt":"Indica que algo não intencional acabou acontecendo.","fr":"Indique qu'un événement non intentionnel a fini par se produire." },
  "아나이스: 어제 면접 본다고 했는데 잘 봤어요?": { "ne":"आनाइस: हिजो अन्तर्वार्ता दिन्छु भन्नुभएको थियो, राम्रो भयो?","bn":"আনাইস: কাল ইন্টারভিউ দেবেন বলেছিলেন, ভালো হয়েছে?","ru":"Анаис: Вы говорили, что вчера у вас собеседование — как прошло?","he":"אנאיס: אמרת שיש לך ראיון אתמול, הלך טוב?","ms":"Anais: Awak kata ada temu duga semalam, bagaimana? Berjaya?","vi":"Anais: Bạn nói hôm qua đi phỏng vấn, có tốt không?","id":"Anais: Kemarin katanya ada wawancara, lancar tidak?","si":"අනායිස්: ඊයේ සම්මුඛ පරීක්ෂණයට යනවා කිව්වනේ, හොඳට ගියාද?","pt":"Anaïs: Você disse que tinha uma entrevista ontem — correu bem?","fr":"Anaïs : Tu avais dit passer un entretien hier, ça s'est bien passé ?" },
  "제이 슨:아니요, 면접관 질문을 잘못 이해해서 동문서답하고 말았어요": { "ne":"जेसन: होइन, अन्तर्वार्ताकर्ताको प्रश्न गलत बुझेर बेतुकको जवाफ दिइहालेँ।","bn":"জেসন: না, ইন্টারভিউয়ারের প্রশ্ন ভুল বুঝে অপ্রাসঙ্গিক উত্তর দিয়ে ফেললাম।","ru":"Джейсон: Нет, я неправильно понял вопрос интервьюера и в итоге ответил невпопад.","he":"ג'ייסון: לא, לא הבנתי נכון את שאלת המראיין ובסוף עניתי תשובה לא קשורה.","ms":"Jason: Tidak, saya salah faham soalan penemu duga lalu memberi jawapan yang tidak berkaitan.","vi":"Jason: Không, tôi hiểu sai câu hỏi của người phỏng vấn nên đã trả lời lạc đề.","id":"Jason: Tidak, saya salah paham pertanyaan pewawancara dan malah menjawab ngawur.","si":"ජේසන්: නෑ, සම්මුඛ පරීක්ෂකයාගේ ප්‍රශ්නය වැරදියට තේරුම් අරගෙන අදාළ නැති පිළිතුරක් දීලා දැම්මා.","pt":"Jason: Não, entendi errado a pergunta do entrevistador e acabei dando uma resposta sem relação.","fr":"Jason : Non, j'ai mal compris la question de l'examinateur et j'ai fini par répondre à côté.","ta":"ஜேசன்: இல்லை, நேர்காணல் செய்பவரின் கேள்வியைத் தவறாகப் புரிந்துகொண்டு பொருத்தமற்ற பதில் சொல்லிவிட்டேன்." },
  "제 발음이 부정확해서 사람들이 잘못 알아듣고 말았어요": { "ne":"मेरो उच्चारण अशुद्ध भएकाले मानिसहरूले गलत बुझिहाले।","bn":"আমার উচ্চারণ ভুল হওয়ায় মানুষজন ভুল বুঝে ফেলল।","ru":"Из-за моего неправильного произношения люди меня неверно поняли.","he":"ההגייה שלי לא הייתה מדויקת, ולכן אנשים הבינו אותי לא נכון.","ms":"Sebutan saya tidak tepat, jadi orang salah faham.","vi":"Phát âm của tôi không chuẩn nên mọi người đã nghe nhầm.","id":"Pengucapan saya tidak akurat, jadi orang-orang salah menangkap.","si":"මගේ උච්චාරණය නිවැරදි නොවුණු නිසා මිනිසුන් වැරදියට තේරුම් අරගෙන දැම්මා.","pt":"Minha pronúncia era imprecisa, então as pessoas acabaram me entendendo mal.","fr":"Ma prononciation était incorrecte, alors les gens m'ont mal compris." },
  "회의할 때 실수한 것이 있어요?": { "ne":"बैठकको बेला केही गल्ती गर्नुभयो?","bn":"মিটিংয়ের সময় কোনো ভুল করেছিলেন?","ru":"Вы допустили какие-нибудь ошибки во время совещания?","he":"עשית טעות כלשהי במהלך הישיבה?","ms":"Adakah anda membuat kesilapan semasa mesyuarat?","vi":"Bạn có mắc lỗi gì trong cuộc họp không?","id":"Apakah Anda membuat kesalahan saat rapat?","si":"රැස්වීමේදී ඔබ යම් වැරැද්දක් කළාද?","pt":"Você cometeu algum erro durante a reunião?","fr":"Avez-vous fait une erreur pendant la réunion ?" },
  "발음이 부정확해서 사람들이 잘못 알아듣다": { "ne":"उच्चारण अशुद्ध भएर मानिसहरूले गलत बुझ्नु","bn":"উচ্চারণ ভুল হওয়ায় মানুষ ভুল বোঝা","ru":"из-за неточного произношения люди неправильно понимают","he":"ההגייה לא מדויקת ולכן אנשים מבינים לא נכון","ms":"sebutan tidak tepat menyebabkan orang salah faham","vi":"phát âm không chuẩn nên mọi người nghe nhầm","id":"pengucapan tidak akurat sehingga orang salah menangkap","si":"උච්චාරණය නිවැරදි නැති නිසා මිනිසුන් වැරදියට තේරුම් ගැනීම","pt":"a pronúncia é imprecisa, então as pessoas entendem mal","fr":"la prononciation est incorrecte, donc les gens comprennent mal" },
  "단어가 잘 안 떠올라서 모국어를 섞어 쓰다": { "ne":"शब्दहरू सम्झना नआएर मातृभाषा मिसाएर प्रयोग गर्नु","bn":"শব্দ মনে না আসায় মাতৃভাষা মিশিয়ে ব্যবহার করা","ru":"слова не приходят на ум, поэтому смешивают с родным языком","he":"המילים לא עולות בראש, ולכן מערבבים את שפת האם","ms":"kata-kata tidak terlintas, jadi mencampurkan bahasa ibunda","vi":"không nghĩ ra từ nên pha trộn tiếng mẹ đẻ vào","id":"kata-kata tidak terpikirkan sehingga mencampur bahasa ibu","si":"වචන මතකයට නොඑන නිසා මව් භාෂාව මිශ්‍ර කර භාවිතා කිරීම","pt":"as palavras não vêm à mente, então mistura-se a língua materna","fr":"les mots ne viennent pas, alors on mélange sa langue maternelle" },
  "높임말이 햇갈려서 과장님께 반말을하다": { "ne":"आदरार्थी शब्दमा अलमल भएर म्यानेजरसँग अनौपचारिक रूपमा बोल्नु","bn":"সম্মানসূচক ভাষা গুলিয়ে ফেলে ম্যানেজারের সঙ্গে অসম্মানজনকভাবে কথা বলা","ru":"запутаться в вежливой речи и заговорить с начальником на «ты»","he":"להתבלבל בלשון הכבוד ולדבר עם המנהל בלשון לא רשמית","ms":"keliru dengan bahasa hormat lalu bercakap tidak formal kepada ketua","vi":"bối rối với kính ngữ nên nói trống không với trưởng phòng","id":"bingung dengan bahasa hormat lalu berbicara tidak sopan kepada manajer","si":"ගෞරව වචන පටලවා ගෙන කළමනාකරුට අගෞරව ලෙස කතා කිරීම","pt":"confundir-se com a linguagem honorífica e falar informalmente com o gerente","fr":"se tromper dans le langage honorifique et parler familièrement au chef","ta":"மரியாதைச் சொற்களில் குழம்பி மேலாளரிடம் மரியாதையின்றிப் பேசுதல்" },
  "한국에 처음 왔을 때는 적응하느라고 힘들었지만, 시간이 지날수록 한국 생활에 익숙해졌어요.": { "ne":"कोरिया पहिलो पटक आउँदा अनुकूलन हुन गाह्रो थियो, तर समय बित्दै जाँदा कोरियाली जीवनमा बानी परेँ।","ta":"நான் முதன்முதலில் கொரியாவுக்கு வந்தபோது தழுவிக்கொள்வது கடினமாக இருந்தது, ஆனால் நேரம் செல்லச் செல்ல கொரிய வாழ்க்கைக்குப் பழகிவிட்டேன்." },
  "직장을 구하느라고 정신이 없었는데, 한국어 실력이 늘수록 일자리를 찾기가 쉬워졌어요.": { "ne":"जागिर खोज्दा निकै व्यस्त थिएँ, तर कोरियन भाषा सिप बढ्दै जाँदा काम खोज्न सजिलो भयो।","ta":"வேலை தேடுவதில் மும்முரமாக இருந்தேன், ஆனால் கொரிய மொழித் திறன் மேம்பட மேம்பட வேலை தேடுவது எளிதாகிவிட்டது." },
  "외로움보다 호기심이 앞서고, 한국 생활에 익숙해지니 자신감도 생겼습니다.": { "ta":"தனிமையை விட ஆர்வம் முந்திக்கொண்டது, கொரிய வாழ்க்கைக்குப் பழகியதும் தன்னம்பிக்கையும் வந்தது." },
  "반면에, 조기적응프로그램은 한국 입국 초기의 이민자가 참가하며, 체류 유형에 따라 한국 생활에 빠르게 적응하도록 도와줍니다.": { "ta":"மறுபுறம், ஆரம்பகால தழுவல் திட்டத்தில் கொரியாவுக்கு வந்த ஆரம்பக் கட்டப் புலம்பெயர்ந்தோர் பங்கேற்கின்றனர்; தங்கும் வகைக்கேற்பக் கொரிய வாழ்க்கைக்கு விரைவாகப் பழக இது உதவுகிறது." },
  "언어 예절을 지키다": { "ne":"भाषिक शिष्टाचार पालना गर्नु","bn":"ভাষার শিষ্টাচার মেনে চলা","ru":"соблюдать речевой этикет","he":"לשמור על נימוסי לשון","ms":"menjaga adab berbahasa","vi":"giữ phép tắc trong lời nói","id":"menjaga etika berbahasa","si":"භාෂා ආචාරධර්ම රැකීම","pt":"observar a etiqueta linguística","fr":"respecter les convenances de langage","ta":"மொழி நாகரிகத்தைக் கடைப்பிடித்தல்" },
  "올바른 언어를 사용하다": { "ne":"सही भाषा प्रयोग गर्नु","bn":"সঠিক ভাষা ব্যবহার করা","ru":"использовать правильный язык","he":"להשתמש בשפה תקינה","ms":"menggunakan bahasa yang betul","vi":"sử dụng ngôn ngữ đúng đắn","id":"menggunakan bahasa yang benar","si":"නිවැරදි භාෂාව භාවිතා කිරීම","pt":"usar a língua corretamente","fr":"utiliser un langage correct","ta":"சரியான மொழியைப் பயன்படுத்துதல்" },
  "때와 장소에 맞게 말하다": { "ne":"समय र स्थान अनुसार बोल्नु","bn":"সময় ও স্থান অনুযায়ী কথা বলা","ru":"говорить сообразно времени и месту","he":"לדבר בהתאם לזמן ולמקום","ms":"bercakap mengikut masa dan tempat","vi":"nói phù hợp với thời điểm và nơi chốn","id":"berbicara sesuai waktu dan tempat","si":"කාලයට හා ස්ථානයට ගැළපෙන ලෙස කතා කිරීම","pt":"falar de acordo com o momento e o lugar","fr":"parler selon le moment et le lieu","ta":"நேரத்திற்கும் இடத்திற்கும் ஏற்பப் பேசுதல்" },
  "표준어를 구사하다": { "ne":"मानक भाषा प्रयोग गर्नु","bn":"প্রমিত ভাষায় কথা বলা","ru":"владеть литературным (стандартным) языком","he":"לדבר בשפה תקנית","ms":"bertutur dalam bahasa baku","vi":"sử dụng ngôn ngữ chuẩn","id":"menggunakan bahasa baku","si":"ප්‍රමිත භාෂාව භාවිතා කිරීම","pt":"falar a língua padrão","fr":"s'exprimer en langue standard","ta":"நியமமொழியைப் பேசுதல்" },
  "정확하게 발음하다": { "ne":"सही उच्चारण गर्नु","bn":"সঠিকভাবে উচ্চারণ করা","ru":"произносить правильно","he":"לבטא במדויק","ms":"menyebut dengan tepat","vi":"phát âm chính xác","id":"mengucapkan dengan tepat","si":"නිවැරදිව උච්චාරණය කිරීම","pt":"pronunciar corretamente","fr":"prononcer correctement","ta":"துல்லியமாக உச்சரித்தல்" },
  "적절한 호칭을 쓰다": { "ne":"उपयुक्त सम्बोधन प्रयोग गर्नु","bn":"উপযুক্ত সম্বোধন ব্যবহার করা","ru":"использовать подходящее обращение","he":"להשתמש בכינוי פנייה מתאים","ms":"menggunakan panggilan yang sesuai","vi":"dùng cách xưng hô phù hợp","id":"menggunakan sapaan yang tepat","si":"සුදුසු ආමන්ත්‍රණය භාවිතා කිරීම","pt":"usar a forma de tratamento adequada","fr":"employer le terme d'adresse approprié","ta":"பொருத்தமான விளிப்பெயரைப் பயன்படுத்துதல்" },
  "비속어를 사용하지 않다": { "ne":"अपशब्द प्रयोग नगर्नु","bn":"অশ্লীল/স্ল্যাং শব্দ ব্যবহার না করা","ru":"не использовать бранные слова","he":"לא להשתמש בשפה גסה","ms":"tidak menggunakan bahasa kasar","vi":"không dùng từ ngữ thô tục","id":"tidak menggunakan kata-kata kasar","si":"අශිෂ්ට වචන භාවිතා නොකිරීම","pt":"não usar palavrões nem gírias","fr":"ne pas employer de mots vulgaires","ta":"கொச்சைச் சொற்களைப் பயன்படுத்தாதிருத்தல்" },
  "단어가 잘 안 떠오르다": { "ne":"शब्दहरू सजिलै सम्झना नआउनु","bn":"শব্দ সহজে মনে না আসা","ru":"слова с трудом приходят на ум","he":"מילים לא עולות בקלות בראש","ms":"kata-kata sukar terlintas di fikiran","vi":"không nghĩ ra được từ","id":"kata-kata sulit terpikirkan","si":"වචන පහසුවෙන් මතකයට නොඒම","pt":"as palavras não vêm facilmente à mente","fr":"les mots ne viennent pas facilement à l'esprit","ta":"சொற்கள் எளிதில் நினைவுக்கு வராமை" },
  "모국어를 섞어쓰다": { "ne":"मातृभाषा मिसाएर प्रयोग गर्नु","bn":"মাতৃভাষা মিশিয়ে ব্যবহার করা","ru":"смешивать с родным языком","he":"לערבב את שפת האם","ms":"mencampurkan bahasa ibunda","vi":"pha trộn tiếng mẹ đẻ","id":"mencampur bahasa ibu","si":"මව් භාෂාව මිශ්‍ර කර භාවිතා කිරීම","pt":"misturar a língua materna","fr":"mélanger sa langue maternelle","ta":"தாய்மொழியைக் கலந்து பயன்படுத்துதல்" },
  "사투리를쓰다": { "ne":"क्षेत्रीय लवज प्रयोग गर्नु","bn":"আঞ্চলিক ভাষা ব্যবহার করা","ru":"говорить на диалекте","he":"לדבר בניב מקומי","ms":"menggunakan loghat atau dialek","vi":"dùng phương ngữ","id":"menggunakan dialek","si":"ප්‍රාදේශීය භාෂාව භාවිතා කිරීම","pt":"usar dialeto","fr":"parler en dialecte","ta":"வட்டார வழக்கைப் பயன்படுத்துதல்" },
  "발음!": { "ne":"उच्चारण!","bn":"উচ্চারণ!","ru":"Произношение!","he":"הגייה!","ms":"Sebutan!","vi":"Phát âm!","id":"Pengucapan!","si":"උච්චාරණය!","pt":"Pronúncia!","fr":"La prononciation !","ta":"உச்சரிப்பு!" },
  "신조어??": { "ne":"नयाँ शब्दहरू??","bn":"নতুন শব্দ (নিওলজিজম)??","ru":"Неологизмы??","he":"מילים חדשות (ניאולוגיזמים)??","ms":"Kata baharu (neologisme)??","vi":"Từ mới??","id":"Kata baru (neologisme)??","si":"නව වචන??","pt":"Neologismos??","fr":"Les néologismes ??","ta":"புதிய சொற்கள்??" }
}
